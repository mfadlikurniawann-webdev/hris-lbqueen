{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/style/(.*)",
      "dest": "/public/style/$1"
    },
    {
      "src": "/logo/(.*)",
      "dest": "/public/logo/$1"
    },
    {
      "src": "/login",
      "dest": "/api/login.php"
    },
    {
      "src": "/logout",
      "dest": "/api/logout.php"
    },
    {
      "src": "/proses_login",
      "dest": "/api/proses_login.php"
    },
    {
      "src": "/proses_absen",
      "dest": "/api/proses_absen.php"
    },
    {
      "src": "/proses_pengajuan",
      "dest": "/api/proses_pengajuan.php"
    },
    {
      "src": "/proses_approval",
      "dest": "/api/proses_approval.php"
    }
  },
  {
    "src": "/cetak_rekap",
    "dest": "/api/cetak_rekap.php"
  },
  {
    "src": "/cetak_pribadi",
    "dest": "/api/cetak_pribadi.php"
  },
  {
    "src": "/(.*)\\.php",
    "dest": "/api/$1.php"
  },
  {
    "src": "/",
    "dest": "/api/index.php"
  },
  {
    "src": "/(.*)",
    "dest": "/api/$1.php"
  },
  {
    "src": "/ganti_password",
    "dest": "/api/ganti_password.php"
  }
]
}